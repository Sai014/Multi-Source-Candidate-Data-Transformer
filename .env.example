# Environment variables for the Multi-Source Candidate Data Transformer.
# Copy this file to `.env` and fill in values as needed. Nothing here is required
# for the default setup: the GLiNER model (urchade/gliner_medium-v2.1) is PUBLIC,
# so it downloads from the Hugging Face Hub without any credentials.
#
# NOTE: GLiNER itself has no API/access key. It runs locally. The only token that
# can matter is a Hugging Face Hub token, and only for private/gated models or to
# raise anonymous download rate limits. The huggingface_hub library reads these
# variables automatically; no code change is needed.

# --- Hugging Face Hub (OPTIONAL) ---------------------------------------------
# Personal access token from https://huggingface.co/settings/tokens
# Only needed for gated/private models or to avoid rate limits on downloads.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HUGGINGFACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where downloaded model weights are cached (defaults to the OS user cache dir).
# HF_HOME=~/.cache/huggingface

# Run fully offline after the model has been cached once (0 = online, 1 = offline).
# HF_HUB_OFFLINE=0
